[Desktop Entry]
Name=madOS Audio Player
Comment=Winamp-inspired audio player
Exec=/usr/local/bin/mados-audio-player %f
Icon=audio-x-generic
Terminal=false
Type=Application
Categories=Audio;Music;Player;
MimeType=audio/mpeg;audio/flac;audio/ogg;audio/wav;audio/aac;audio/x-opus;
StartupWMClass=mados-audio-player
StartupNotify=true
